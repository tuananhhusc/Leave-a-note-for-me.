# Supabase Configuration (Public - accessible in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (Server-side only - NEVER expose to client)
# Get this from: Supabase Dashboard -> Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin Password (Server-side only - used for admin API authentication)
# This password is used to authenticate admin actions via API routes
# IMPORTANT: Keep this secret. Do NOT use NEXT_PUBLIC_ prefix.
ADMIN_PASSWORD=your-secure-admin-password-here

# (DEPRECATED - Do NOT use) Old client-side password variable
# NEXT_PUBLIC_ADMIN_PASSWORD is no longer used. Remove if present.
# All admin auth now goes through the server-side API.
